{
  "name": "devote",
  "version": "1.2.41",
  "description": "A distraction-free daily Christian devotional app",
  "main": "./out/main/index.js",
  "author": "Devote",
  "repository": {
    "type": "git",
    "url": "https://github.com/robrochford/Devote.git"
  },
  "homepage": "https://github.com/robrochford/Devote",
  "scripts": {
    "format": "prettier --write .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win",
    "release:win": "npm run build && electron-builder --win -p always",
    "release:mac": "npm run build && electron-builder --mac -p always",
    "snapshot": "node scripts/snapshot.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "archiver": "^7.0.1",
    "cross-env": "^10.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  }
}
